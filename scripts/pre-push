#!/bin/sh
# 发版前最后一道提醒：push master 且含 CHANGELOG 改动时确认
# 交互终端下会等待确认；CI / 非交互环境自动放行。

# ── T1: README / deploy-doc vs agents model consistency ──
# 非交互环境（CI）自动放行，本地交互终端阻断不一致提交
if [ -t 1 ]; then
  pwsh -File ".opencode/tests/T1-readme-consistency.ps1" >/dev/null 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ T1 一致性检查失败：README / 部署手册与 .opencode/agents 的 model 分配不一致。"
    echo "   请先同步（改 agents 的 model 后，同步 7 个 README 图表 + 2 个部署手册），再 push。"
    echo "   跳过检查：git push --no-verify"
    exit 1
  fi
fi

master_push=0
while read -r lref lobj rref robj; do
  [ "$lref" = "refs/heads/master" ] && master_push=1
done
[ "$master_push" -eq 0 ] && exit 0

remote="$1"
if git diff --quiet "$remote/master" HEAD -- CHANGELOG.md 2>/dev/null; then
  exit 0
fi

VER=$(grep -m1 -E '^## +v[0-9]+\.[0-9]+\.[0-9]+' CHANGELOG.md | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+')
[ -z "$VER" ] && exit 0

echo "🚀 即将发版：$VER"
echo "   CHANGELOG.md 有改动，push 后会自动：打 tag + 建 Release + 上传 zip/tar.gz 归档。"
if [ -t 1 ]; then
  printf "   按 Enter 继续发版，Ctrl+C 取消："
  read -r _ || exit 1
else
  echo "   （非交互环境，自动继续）"
fi
