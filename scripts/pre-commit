#!/bin/sh
# 本地提醒：改动 CHANGELOG.md 会在 push 到 master 时自动发版
# 仅作提示，不阻断提交。
if git diff --cached --name-only | grep -qx 'CHANGELOG.md'; then
  VER=$(grep -m1 -E '^## +v[0-9]+\.[0-9]+\.[0-9]+' CHANGELOG.md | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+')
  if [ -n "$VER" ] && ! git rev-parse "$VER" >/dev/null 2>&1; then
    echo "📝 提示：你改了 CHANGELOG.md，头部版本为 $VER。"
    echo "   push 到 master 后会自动打 tag + 建 Release。别忘了 push！"
  fi
fi
